  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "test": "jest",
    "test:watch": "jest --watch",
    "format": "prettier --write \"src/**/*.{ts,tsx,js,css}\"",
    "format:check": "prettier --check \"src/**/*.{ts,tsx,js,css}\""
  },
  "keywords": [
